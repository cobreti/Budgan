{
    "name": "bugdan",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:budgan": "vite serve ./config/budgan --config ./config/budgan/vite.config.ts",
        "dev:engine-testapp": "vite serve ./config/engine-testapp --config ./config/engine-testapp/vite.config.ts",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "coverage": "vitest run --coverage",
        "test:unit": "vitest",
        "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
        "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
        "build:budgan": "vite build ./config/budgan --config ./config/budgan/vite.config.ts",
        "build:engine-testapp": "vite build ./config/engine-testapp --config ./config/engine-testapp/vite.config.ts",
        "type-check:budgan": "vue-tsc --build tsconfig.budgan.json --force",
        "type-check:engine-testapp": "vue-tsc --build tsconfig.engine-testapp.json --force",
        "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
        "format": "prettier --write src/"
    },
    "dependencies": {
        "csv-parse": "^6.1.0",
        "fflate": "^0.8.2",
        "inversify": "^7.11.0",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "reflect-metadata": "^0.2.2",
        "vee-validate": "^4.15.1",
        "vite-plugin-sass-dts": "^1.3.35",
        "vue": "^3.5.29",
        "vue-router": "^5.0.3",
        "vuetify": "^4.0.1"
    },
    "devDependencies": {
        "@mdi/font": "^7.4.47",
        "@rushstack/eslint-patch": "^1.16.1",
        "@tsconfig/node18": "^18.2.6",
        "@types/jsdom": "^28.0.0",
        "@types/node": "^25.3.5",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vitejs/plugin-vue-jsx": "^5.1.4",
        "@vue/eslint-config-prettier": "^10.0.2",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.0",
        "cypress": "^15.11.0",
        "eslint": "^10.0.3",
        "eslint-plugin-cypress": "^6.1.0",
        "eslint-plugin-vue": "^10.8.0",
        "jsdom": "^28.1.0",
        "less": "^4.5.1",
        "less-loader": "^12.3.1",
        "lorem-ipsum": "^2.0.8",
        "material-design-icons-iconfont": "^6.7.0",
        "moment": "^2.30.1",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.8.1",
        "rxjs": "^7.8.2",
        "start-server-and-test": "^2.1.5",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18",
        "vue-tsc": "^3.2.5"
    }
}
